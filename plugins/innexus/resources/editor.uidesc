    <view class="FieldsetContainer" origin="405, 465" size="390, 130"
          title="Blend" fieldset-title="Blend" fieldset-color="text-dim"
          fieldset-title-color="text-fieldset">

      <!-- FR-042: Blend Enable -->
      <view class="ToggleButton" origin="10, 20" size="28, 28"
