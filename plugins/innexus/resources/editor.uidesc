            title="Live"/>
    </view>

    <!-- ============================================================== -->
    <!-- EXCITER SECTION (Y 600-690)                                    -->
    <!-- Signal path: exciter -> resonator bank                         -->
    <!-- ============================================================== -->
    <view class="FieldsetContainer" origin="5, 600" size="790, 90"
          title="Exciter" fieldset-title="Exciter" fieldset-color="text-dim"
          fieldset-title-color="text-fieldset">

      <!-- Exciter Type selector (Residual / Impact / Bow) -->
      <view class="COptionMenu" origin="15, 22" size="100, 22"
            control-tag="ExciterType" default-value="0"
            font="label-font" font-color="text-primary"
            back-color="bg-panel" frame-color="text-dim"/>
      <view class="CTextLabel" origin="15, 46" size="100, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Type"/>

      <!-- Impact-specific knobs (visibility controlled by ExciterType parameter) -->
      <view class="CViewContainer" origin="130, 0" size="660, 90"
            background-color="~ TransparentCColor">

        <!-- Hardness (mallet softness to metallic click) -->
        <view class="ArcKnob" origin="45, 18" size="42, 42"
              control-tag="ImpactHardness" default-value="0.5"
              arc-color="accent"/>
        <view class="CParamDisplay" origin="40, 60" size="52, 12"
              control-tag="ImpactHardness" font="value-font"
              font-color="text-primary" back-color="~ TransparentCColor"
              text-alignment="center"/>
        <view class="CTextLabel" origin="40, 72" size="52, 10"
              text-alignment="center" font="value-font"
              font-color="text-secondary" back-color="~ TransparentCColor"
              title="Hard"/>

        <!-- Mass (pulse duration: light tap to heavy thud) -->
        <view class="ArcKnob" origin="185, 18" size="42, 42"
              control-tag="ImpactMass" default-value="0.3"
              arc-color="accent"/>
        <view class="CParamDisplay" origin="180, 60" size="52, 12"
              control-tag="ImpactMass" font="value-font"
              font-color="text-primary" back-color="~ TransparentCColor"
              text-alignment="center"/>
        <view class="CTextLabel" origin="180, 72" size="52, 10"
              text-alignment="center" font="value-font"
              font-color="text-secondary" back-color="~ TransparentCColor"
              title="Mass"/>

        <!-- Brightness (trim: dark to bright override) -->
        <view class="ArcKnob" origin="325, 18" size="42, 42"
              control-tag="ImpactBrightness" default-value="0.5"
              arc-color="accent"/>
        <view class="CParamDisplay" origin="320, 60" size="52, 12"
              control-tag="ImpactBrightness" font="value-font"
              font-color="text-primary" back-color="~ TransparentCColor"
              text-alignment="center"/>
        <view class="CTextLabel" origin="320, 72" size="52, 10"
              text-alignment="center" font="value-font"
              font-color="text-secondary" back-color="~ TransparentCColor"
              title="Bright"/>

        <!-- Position (strike position: edge to center) -->
        <view class="ArcKnob" origin="465, 18" size="42, 42"
              control-tag="ImpactPosition" default-value="0.13"
              arc-color="accent"/>
        <view class="CParamDisplay" origin="460, 60" size="52, 12"
              control-tag="ImpactPosition" font="value-font"
              font-color="text-primary" back-color="~ TransparentCColor"
              text-alignment="center"/>
        <view class="CTextLabel" origin="460, 72" size="52, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Pos"/>
      </view> <!-- end Impact-specific knobs container -->
    </view> <!-- end Exciter FieldsetContainer -->

    <!-- ============================================================== -->
    <!-- RESONATOR BANK SECTION (Y 695-805)                             -->
    <!-- Physical modelling: residual -> modal resonator -> mix         -->
    <!-- ============================================================== -->
    <view class="FieldsetContainer" origin="5, 695" size="790, 110"
          title="Resonator Bank" fieldset-title="Resonator Bank" fieldset-color="text-dim"
          fieldset-title-color="text-fieldset">

      <!-- Physical Model Mix (dry/wet blend) -->
      <view class="ArcKnob" origin="55, 18" size="42, 42"
            control-tag="PhysModelMix" default-value="0"
            arc-color="accent"/>
      <view class="CParamDisplay" origin="50, 60" size="52, 12"
            control-tag="PhysModelMix" font="value-font"
            font-color="text-primary" back-color="~ TransparentCColor"
