      <!-- Decay Curve -->
      <view class="ArcKnob" origin="710, 14" size="34, 34"
            control-tag="AdsrDecayCurve" default-value="0.5"
            arc-color="accent"/>
      <view class="CTextLabel" origin="706, 48" size="42, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="D Crv"/>

      <!-- Release Curve -->
      <view class="ArcKnob" origin="755, 14" size="34, 34"
            control-tag="AdsrReleaseCurve" default-value="0.5"
            arc-color="accent"/>
      <view class="CTextLabel" origin="751, 48" size="42, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="R Crv"/>

    </view>

    <!-- Bottom credit line (version from version.h) -->
    <view class="CTextLabel" custom-view-name="VersionLabel"
          origin="575, 1016" size="220, 14"
          text-alignment="right" font="value-font"
          font-color="text-dim" back-color="~ TransparentCColor"/>

    <!-- Update Banner (last child = highest z-index, paints on top of everything) -->
    <view custom-view-name="UpdateBanner" origin="0, 0" size="800, 60" autosize="left right"/>
  </template>

  <!-- ================================================================== -->
  <!-- Modulator Panel Template (FR-046: single definition, used twice)   -->
  <!-- FR-037 to FR-040                                                    -->
  <!-- ================================================================== -->
  <template name="modulator_panel" class="FieldsetContainer" size="195, 130"
            title="Modulator" fieldset-title="Modulator" fieldset-color="text-dim"
            fieldset-title-color="text-fieldset">

    <!-- Enable toggle -->
    <view class="ToggleButton" origin="10, 18" size="24, 24"
          control-tag="Mod.Enable" default-value="0"
          on-color="accent" off-color="text-dim"/>
    <view class="CTextLabel" origin="5, 42" size="34, 10"
          text-alignment="center" font="value-font"
          font-color="text-secondary" back-color="~ TransparentCColor"
          title="Enable"/>

    <!-- Waveform selector -->
    <view class="COptionMenu" origin="40, 20" size="90, 20"
          control-tag="Mod.Waveform" default-value="0"
          font="value-font" font-color="text-primary"
          back-color="bg-panel" frame-color="text-dim"/>
    <view class="CTextLabel" origin="40, 40" size="90, 10"
          text-alignment="center" font="value-font"
          font-color="text-secondary" back-color="~ TransparentCColor"
          title="Waveform"/>

    <!-- Activity indicator (FR-038, FR-040) -->
    <view class="CView" custom-view-name="ModulatorActivity"
          origin="140, 18" size="25, 25"/>

    <!-- Rate knob + Sync toggle button -->
    <view class="ArcKnob" origin="10, 50" size="29, 29"
          control-tag="Mod.Rate" default-value="0.5"
          arc-color="accent"/>
    <view class="CTextLabel" origin="6, 79" size="37, 10"
          text-alignment="center" font="value-font"
          font-color="text-secondary" back-color="~ TransparentCColor"
          title="Rate"/>
    <view class="ToggleButton" origin="8, 89" size="33, 9"
          control-tag="Mod.RateSync" default-value="1"
          title="sync" font="value-font"
          on-color="accent" off-color="text-dim"/>

    <!-- Depth -->
    <view class="ArcKnob" origin="52, 50" size="29, 29"
          control-tag="Mod.Depth" default-value="0"
          arc-color="accent"/>
    <view class="CTextLabel" origin="48, 79" size="37, 10"
          text-alignment="center" font="value-font"
          font-color="text-secondary" back-color="~ TransparentCColor"
          title="Depth"/>

    <!-- Range Start -->
    <view class="ArcKnob" origin="94, 50" size="29, 29"
          control-tag="Mod.RangeStart" default-value="0"
          arc-color="accent"/>
    <view class="CTextLabel" origin="90, 79" size="37, 10"
          text-alignment="center" font="value-font"
          font-color="text-secondary" back-color="~ TransparentCColor"
          title="Start"/>

    <!-- Range End -->
    <view class="ArcKnob" origin="136, 50" size="29, 29"
          control-tag="Mod.RangeEnd" default-value="1"
          arc-color="accent"/>
    <view class="CTextLabel" origin="132, 79" size="37, 10"
          text-alignment="center" font="value-font"
          font-color="text-secondary" back-color="~ TransparentCColor"
          title="End"/>

    <!-- Target selector (3 segments) -->
    <view class="CSegmentButton" origin="10, 98" size="160, 20"
          control-tag="Mod.Target" default-value="0"
          font="value-font" text-color="text-secondary"
          text-color-highlighted="text-primary"
          frame-color="text-dim" gradient="segment-bg"
          gradient-highlighted="segment-bg-selected"
          segment-names="Amp,Freq,Pan"
          style="horizontal" round-radius="3"/>
    <view class="CTextLabel" origin="10, 118" size="160, 10"
          text-alignment="center" font="value-font"
          font-color="text-secondary" back-color="~ TransparentCColor"
          title="Target"/>
  </template>

</vstgui-ui-description>
