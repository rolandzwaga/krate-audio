      <view class="CTextLabel" origin="50, 72" size="52, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Mix"/>

      <!-- Decay (ring-out time, log-mapped 0.01-5.0s) -->
      <view class="ArcKnob" origin="195, 18" size="42, 42"
            control-tag="ResonanceDecay" default-value="0.63"
            arc-color="accent"/>
      <view class="CParamDisplay" origin="190, 60" size="52, 12"
            control-tag="ResonanceDecay" font="value-font"
            font-color="text-primary" back-color="~ TransparentCColor"
