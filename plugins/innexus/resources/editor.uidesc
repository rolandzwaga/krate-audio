      <view class="CTextLabel" origin="190, 72" size="52, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Decay"/>

      <!-- Brightness (material character: wood=0 to metal=1) -->
      <view class="ArcKnob" origin="335, 18" size="42, 42"
            control-tag="ResonanceBrightness" default-value="0.5"
            arc-color="accent"/>
      <view class="CParamDisplay" origin="330, 60" size="52, 12"
            control-tag="ResonanceBrightness" font="value-font"
            font-color="text-primary" back-color="~ TransparentCColor"
            text-alignment="center"/>
      <view class="CTextLabel" origin="330, 72" size="52, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Bright"/>

      <!-- Stretch (stiff-string inharmonicity) -->
      <view class="ArcKnob" origin="475, 18" size="42, 42"
            control-tag="ResonanceStretch" default-value="0"
            arc-color="accent"/>
      <view class="CParamDisplay" origin="470, 60" size="52, 12"
            control-tag="ResonanceStretch" font="value-font"
            font-color="text-primary" back-color="~ TransparentCColor"
            text-alignment="center"/>
      <view class="CTextLabel" origin="470, 72" size="52, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Stretch"/>

      <!-- Scatter (irregular mode displacement) -->
      <view class="ArcKnob" origin="615, 18" size="42, 42"
            control-tag="ResonanceScatter" default-value="0"
            arc-color="accent"/>
      <view class="CParamDisplay" origin="610, 60" size="52, 12"
            control-tag="ResonanceScatter" font="value-font"
            font-color="text-primary" back-color="~ TransparentCColor"
            text-alignment="center"/>
      <view class="CTextLabel" origin="610, 72" size="52, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Scatter"/>
    </view>

