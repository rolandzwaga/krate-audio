      <!-- Amount -->
      <view class="ArcKnob" origin="575, 14" size="34, 34"
            control-tag="AdsrAmount" default-value="0"
            arc-color="accent"/>
      <view class="CTextLabel" origin="571, 48" size="42, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Amount"/>

      <!-- Time Scale -->
      <view class="ArcKnob" origin="620, 14" size="34, 34"
            control-tag="AdsrTimeScale" default-value="0.2"
            arc-color="accent"/>
      <view class="CTextLabel" origin="616, 48" size="42, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Scale"/>

      <!-- Attack Curve -->
      <view class="ArcKnob" origin="665, 14" size="34, 34"
            control-tag="AdsrAttackCurve" default-value="0.5"
            arc-color="accent"/>
      <view class="CTextLabel" origin="661, 48" size="42, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
