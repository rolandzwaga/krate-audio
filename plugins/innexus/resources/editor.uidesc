    <!-- ADSR ENVELOPE SECTION (Y 910-1015)                             -->
    <!-- ============================================================== -->
    <view class="FieldsetContainer" origin="5, 910" size="790, 105"
          title="ADSR Envelope" fieldset-title="ADSR Envelope" fieldset-color="text-dim"
          fieldset-title-color="text-fieldset">

      <!-- ADSRDisplay custom view (T030/T031: interactive envelope visualization) -->
      <view class="CView" custom-view-name="ADSRDisplay" origin="10, 24" size="365, 76"/>

      <!-- Attack -->
      <view class="ArcKnob" origin="385, 14" size="34, 34"
            control-tag="AdsrAttack" default-value="0.27"
            arc-color="accent"/>
      <view class="CTextLabel" origin="381, 48" size="42, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Attack"/>

      <!-- Expand button to open full-width ADSR overlay (below Attack knob) -->
      <view class="CView" custom-view-name="ADSRExpandButton" origin="381, 80" size="42, 14"/>

      <!-- Decay -->
      <view class="ArcKnob" origin="430, 14" size="34, 34"
            control-tag="AdsrDecay" default-value="0.54"
            arc-color="accent"/>
      <view class="CTextLabel" origin="426, 48" size="42, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Decay"/>

      <!-- Sustain -->
      <view class="ArcKnob" origin="475, 14" size="34, 34"
            control-tag="AdsrSustain" default-value="1.0"
            arc-color="accent"/>
      <view class="CTextLabel" origin="471, 48" size="42, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
            title="Sustain"/>

      <!-- Release -->
      <view class="ArcKnob" origin="520, 14" size="34, 34"
            control-tag="AdsrRelease" default-value="0.54"
            arc-color="accent"/>
      <view class="CTextLabel" origin="516, 48" size="42, 10"
            text-alignment="center" font="value-font"
            font-color="text-secondary" back-color="~ TransparentCColor"
