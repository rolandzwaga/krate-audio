    <!-- ============================================================== -->
    <view class="FieldsetContainer" origin="550, 810" size="245, 95"
          title="Feedback" fieldset-title="Feedback" fieldset-color="text-dim"
          fieldset-title-color="text-fieldset">

      <!-- Feedback Amount -->
      <view class="ArcKnob" origin="30, 18" size="42, 42"
            control-tag="FeedbackAmount" default-value="0"
            arc-color="accent"/>
      <view class="CParamDisplay" origin="25, 60" size="52, 12"
            control-tag="FeedbackAmount" font="value-font"
