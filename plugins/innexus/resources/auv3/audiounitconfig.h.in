// Channel capabilities. Format: each digit is one integer, pairs interpreted
// as (input, output) configs. See AUv3Wrapper.mm parser (substringWithRange:1).
//   "0222" = two configs: (0in,2out) + (2in,2out)  (instrument + sidechain)  <- THIS PLUGIN
//   "02"   = one config: 0 in, 2 out               (instrument, no sidechain)
//   "1122" = two configs: (1in,1out) + (2in,2out)  (mono + stereo effect)
// NOTE: "0022" is WRONG — it parses as (0,0)+(2,2), NOT "0 in / 2 out", and makes
// AU host init fail (-10875) by declaring an input bus config the SDK can't map.
#define kSupportedNumChannels     0222

