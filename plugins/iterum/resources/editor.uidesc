<?xml version="1.0" encoding="UTF-8"?>
<vstgui-ui-description version="1">
  <colors>
    <color name="background" rgba="#f8f8f8ff"/>
    <color name="header" rgba="#e8e8e8ff"/>
    <color name="sidebar" rgba="#f0f0f0ff"/>
    <color name="panel" rgba="#f4f4f4ff"/>
    <color name="section" rgba="#eeeeeeff"/>
    <color name="text" rgba="#1a1a1aff"/>
    <color name="text-dim" rgba="#666666ff"/>
    <color name="accent" rgba="#3a80c9ff"/>
    <color name="slider-track" rgba="#ccccccff"/>
    <color name="border" rgba="#d0d0d0ff"/>
    <color name="segment-normal" rgba="#e0e0e0ff"/>
    <color name="segment-selected" rgba="#1a1a1aff"/>
    <color name="text-light" rgba="#ffffffff"/>
  </colors>
  <fonts>
    <font name="title-font" font-name="Arial" size="18" bold="true"/>
    <font name="section-font" font-name="Arial" size="14" bold="true"/>
    <font name="label-font" font-name="Arial" size="9"/>
    <font name="value-font" font-name="Arial" size="10"/>
    <font name="mode-font" font-name="Arial" size="12"/>
  </fonts>
  <control-tags>
    <control-tag name="Gain" tag="1"/>
    <control-tag name="Mode" tag="2"/>
    <control-tag name="GranularGrainSize" tag="100"/>
    <control-tag name="GranularDensity" tag="101"/>
    <control-tag name="GranularDelayTime" tag="102"/>
    <control-tag name="GranularPitch" tag="103"/>
    <control-tag name="GranularPitchSpray" tag="104"/>
    <control-tag name="GranularPositionSpray" tag="105"/>
    <control-tag name="GranularPanSpray" tag="106"/>
    <control-tag name="GranularReverseProb" tag="107"/>
    <control-tag name="GranularFreeze" tag="108"/>
    <control-tag name="GranularFeedback" tag="109"/>
    <control-tag name="GranularDryWet" tag="110"/>
    <control-tag name="GranularEnvelopeType" tag="112"/>
    <control-tag name="GranularTimeMode" tag="113"/>
    <control-tag name="GranularNoteValue" tag="114"/>
    <control-tag name="GranularJitter" tag="115"/>
    <control-tag name="GranularPitchQuant" tag="116"/>
    <control-tag name="GranularTexture" tag="117"/>
    <control-tag name="GranularStereoWidth" tag="118"/>
    <control-tag name="SpectralFFTSize" tag="200"/>
    <control-tag name="SpectralBaseDelay" tag="201"/>
    <control-tag name="SpectralSpread" tag="202"/>
    <control-tag name="SpectralSpreadDirection" tag="203"/>
    <control-tag name="SpectralFeedback" tag="204"/>
    <control-tag name="SpectralFeedbackTilt" tag="205"/>
    <control-tag name="SpectralFreeze" tag="206"/>
    <control-tag name="SpectralDiffusion" tag="207"/>
    <control-tag name="SpectralDryWet" tag="208"/>
    <control-tag name="SpectralSpreadCurve" tag="209"/>
    <control-tag name="SpectralStereoWidth" tag="210"/>
    <control-tag name="SpectralTimeMode" tag="211"/>
    <control-tag name="SpectralNoteValue" tag="212"/>
    <control-tag name="ShimmerDelayTime" tag="300"/>
    <control-tag name="ShimmerPitchSemitones" tag="301"/>
    <control-tag name="ShimmerPitchCents" tag="302"/>
    <control-tag name="ShimmerShimmerMix" tag="303"/>
    <control-tag name="ShimmerFeedback" tag="304"/>
    <control-tag name="ShimmerDiffusionSize" tag="306"/>
    <control-tag name="ShimmerFilterEnabled" tag="307"/>
    <control-tag name="ShimmerFilterCutoff" tag="308"/>
    <control-tag name="ShimmerDryWet" tag="309"/>
    <control-tag name="ShimmerTimeMode" tag="310"/>
    <control-tag name="ShimmerNoteValue" tag="311"/>
    <control-tag name="TapeMotorSpeed" tag="400"/>
    <control-tag name="TapeMotorInertia" tag="401"/>
    <control-tag name="TapeWear" tag="402"/>
    <control-tag name="TapeSaturation" tag="403"/>
    <control-tag name="TapeAge" tag="404"/>
    <control-tag name="TapeSpliceEnabled" tag="405"/>
    <control-tag name="TapeSpliceIntensity" tag="406"/>
    <control-tag name="TapeFeedback" tag="407"/>
    <control-tag name="TapeMix" tag="408"/>
    <control-tag name="TapeHead1Enabled" tag="410"/>
    <control-tag name="TapeHead2Enabled" tag="411"/>
    <control-tag name="TapeHead3Enabled" tag="412"/>
    <control-tag name="TapeHead1Level" tag="413"/>
    <control-tag name="TapeHead2Level" tag="414"/>
    <control-tag name="TapeHead3Level" tag="415"/>
    <control-tag name="TapeHead1Pan" tag="416"/>
    <control-tag name="TapeHead2Pan" tag="417"/>
    <control-tag name="TapeHead3Pan" tag="418"/>
    <control-tag name="BBDDelayTime" tag="500"/>
    <control-tag name="BBDFeedback" tag="501"/>
    <control-tag name="BBDModulationDepth" tag="502"/>
    <control-tag name="BBDModulationRate" tag="503"/>
    <control-tag name="BBDAge" tag="504"/>
    <control-tag name="BBDEra" tag="505"/>
    <control-tag name="BBDMix" tag="506"/>
    <control-tag name="BBDTimeMode" tag="507"/>
    <control-tag name="BBDNoteValue" tag="508"/>
    <control-tag name="DigitalDelayTime" tag="600"/>
    <control-tag name="DigitalTimeMode" tag="601"/>
    <control-tag name="DigitalNoteValue" tag="602"/>
    <control-tag name="DigitalFeedback" tag="603"/>
    <control-tag name="DigitalLimiterCharacter" tag="604"/>
    <control-tag name="DigitalEra" tag="605"/>
    <control-tag name="DigitalAge" tag="606"/>
    <control-tag name="DigitalModDepth" tag="607"/>
    <control-tag name="DigitalModRate" tag="608"/>
    <control-tag name="DigitalModWaveform" tag="609"/>
    <control-tag name="DigitalMix" tag="610"/>
    <control-tag name="DigitalWavefoldAmount" tag="611"/>
    <control-tag name="DigitalWidth" tag="612"/>
    <control-tag name="DigitalWavefoldType" tag="613"/>
    <control-tag name="DigitalWavefoldSymmetry" tag="614"/>
    <control-tag name="PingPongDelayTime" tag="700"/>
    <control-tag name="PingPongTimeMode" tag="701"/>
    <control-tag name="PingPongNoteValue" tag="702"/>
    <control-tag name="PingPongLRRatio" tag="703"/>
    <control-tag name="PingPongFeedback" tag="704"/>
    <control-tag name="PingPongCrossFeedback" tag="705"/>
    <control-tag name="PingPongWidth" tag="706"/>
    <control-tag name="PingPongModDepth" tag="707"/>
    <control-tag name="PingPongModRate" tag="708"/>
    <control-tag name="PingPongMix" tag="709"/>
    <control-tag name="ReverseChunkSize" tag="800"/>
    <control-tag name="ReverseCrossfade" tag="801"/>
    <control-tag name="ReversePlaybackMode" tag="802"/>
    <control-tag name="ReverseFeedback" tag="803"/>
    <control-tag name="ReverseFilterEnabled" tag="804"/>
    <control-tag name="ReverseFilterCutoff" tag="805"/>
    <control-tag name="ReverseFilterType" tag="806"/>
    <control-tag name="ReverseDryWet" tag="807"/>
    <control-tag name="ReverseTimeMode" tag="808"/>
    <control-tag name="ReverseNoteValue" tag="809"/>
    <control-tag name="MultiTapTimingPattern" tag="900"/>
    <control-tag name="MultiTapSpatialPattern" tag="901"/>
    <control-tag name="MultiTapTapCount" tag="902"/>
    <control-tag name="MultiTapFeedback" tag="905"/>
    <control-tag name="MultiTapFeedbackLPCutoff" tag="906"/>
    <control-tag name="MultiTapFeedbackHPCutoff" tag="907"/>
    <control-tag name="MultiTapMorphTime" tag="908"/>
    <control-tag name="MultiTapDryWet" tag="909"/>
    <control-tag name="MultiTapNoteValue" tag="911"/>
    <control-tag name="MultiTapNoteModifier" tag="912"/>
    <control-tag name="MultiTapSnapDivision" tag="913"/>
    <control-tag name="FreezeDryWet" tag="1012"/>
    <control-tag name="FreezePatternType" tag="1015"/>
    <control-tag name="FreezeSliceLength" tag="1016"/>
    <control-tag name="FreezeSliceMode" tag="1017"/>
    <control-tag name="FreezeEuclideanSteps" tag="1020"/>
    <control-tag name="FreezeEuclideanHits" tag="1021"/>
    <control-tag name="FreezeEuclideanRotation" tag="1022"/>
    <control-tag name="FreezePatternRate" tag="1023"/>
    <control-tag name="FreezeGranularDensity" tag="1030"/>
    <control-tag name="FreezeGranularPositionJitter" tag="1031"/>
    <control-tag name="FreezeGranularSizeJitter" tag="1032"/>
    <control-tag name="FreezeGranularGrainSize" tag="1033"/>
    <control-tag name="FreezeDroneVoiceCount" tag="1040"/>
    <control-tag name="FreezeDroneInterval" tag="1041"/>
    <control-tag name="FreezeDroneDrift" tag="1042"/>
    <control-tag name="FreezeDroneDriftRate" tag="1043"/>
    <control-tag name="FreezeNoiseColor" tag="1050"/>
    <control-tag name="FreezeNoiseBurstRate" tag="1051"/>
    <control-tag name="FreezeNoiseFilterType" tag="1052"/>
    <control-tag name="FreezeNoiseFilterCutoff" tag="1053"/>
    <control-tag name="FreezeNoiseFilterSweep" tag="1054"/>
    <control-tag name="FreezeEnvelopeAttack" tag="1060"/>
    <control-tag name="FreezeEnvelopeRelease" tag="1061"/>
    <control-tag name="FreezeEnvelopeShape" tag="1062"/>
    <control-tag name="DigitalAgeLabel" tag="9902"/>
  </control-tags>
  <gradients>
    <gradient name="segment-bg">
      <color-stop rgba="#e8e8e8ff" start="0"/>
      <color-stop rgba="#d8d8d8ff" start="1"/>
    </gradient>
    <gradient name="segment-bg-selected">
      <color-stop rgba="#2a2a2aff" start="0"/>
      <color-stop rgba="#1a1a1aff" start="1"/>
    </gradient>
  </gradients>
  <template name="GranularPanel" class="CViewContainer" origin="0, 0" size="860, 400" background-color="panel" transparent="false">
    <view class="CTextLabel" origin="10, 5" size="200, 22" title="GRANULAR DELAY" font="section-font" font-color="accent" transparent="true"/>
    <view class="FieldsetContainer" origin="10, 30" size="280, 192" fieldset-title="TIME &amp; MIX" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CViewContainer" origin="10, 10" size="55, 68" sub-controller="GranularTimeSyncController" transparent="true">
        <view class="CParamDisplay" control-tag="GranularDelayTime" origin="0, 0" size="55, 13" font="label-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="center" value-precision="0"/>
        <view class="ArcKnob" origin="5, 13" size="45, 45" control-tag="GranularDelayTime" default-value="0.25" arc-color="accent" guide-color="slider-track" arc-width="2.5"/>
        <view class="ToggleButton" origin="3, 55" size="49, 10" control-tag="GranularTimeMode" default-value="0" title="sync" on-color="accent" off-color="text-dim" font-size="7"/>
      </view>
      <view class="CTextLabel" origin="75, 10" size="65, 16" title="Feedback" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularFeedback" origin="140, 10" size="65, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="75, 28" size="195, 20" control-tag="GranularFeedback" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="10, 82" size="130, 16" title="Dry/Wet" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularDryWet" origin="140, 82" size="130, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 100" size="260, 20" control-tag="GranularDryWet" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
    </view>
    <view class="FieldsetContainer" origin="300, 30" size="270, 192" fieldset-title="GRAIN PARAMETERS" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CTextLabel" origin="10, 10" size="35, 16" title="Size" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularGrainSize" origin="45, 10" size="40, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 28" size="75, 20" control-tag="GranularGrainSize" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="95, 10" size="40, 16" title="Density" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularDensity" origin="135, 10" size="35, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="95, 28" size="75, 20" control-tag="GranularDensity" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="180, 10" size="40, 16" title="Pitch" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularPitch" origin="220, 10" size="40, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="180, 28" size="80, 20" control-tag="GranularPitch" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="10, 52" size="50, 16" title="Jitter" font="label-font" font-color="text-dim" transparent="true" text-alignment="left"/>
      <view class="CParamDisplay" control-tag="GranularJitter" origin="205, 52" size="45, 17" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 70" size="240, 20" control-tag="GranularJitter" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="10, 102" size="200, 16" title="Envelope" font="label-font" font-color="text-dim" transparent="true" text-alignment="left"/>
      <view class="CSegmentButton" origin="10, 120" size="240, 22" control-tag="GranularEnvelopeType" style="horizontal" segment-names="Hann,Trapezoid,Sine,Blackman" selection-mode="kSingle" font="value-font" text-color="text" text-color-highlighted="text-light" frame-color="border" gradient="segment-bg" gradient-highlighted="segment-bg-selected"/>
      <view class="CTextLabel" origin="10, 142" size="240, 16" title="Pitch Quantize" font="label-font" font-color="text-dim" transparent="true" text-alignment="left"/>
      <view class="CSegmentButton" origin="10, 160" size="240, 22" control-tag="GranularPitchQuant" style="horizontal" segment-names="Off,Semis,Octs,5ths,Scale" selection-mode="kSingle" font="value-font" text-color="text" text-color-highlighted="text-light" frame-color="border" gradient="segment-bg" gradient-highlighted="segment-bg-selected"/>
    </view>
    <view class="FieldsetContainer" origin="580, 30" size="270, 192" fieldset-title="SPRAY &amp; RANDOMIZATION" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CTextLabel" origin="10, 10" size="30, 16" title="Pitch" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularPitchSpray" origin="35, 10" size="30, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 28" size="55, 20" control-tag="GranularPitchSpray" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="75, 10" size="30, 16" title="Pos" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularPositionSpray" origin="100, 10" size="30, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="75, 28" size="55, 20" control-tag="GranularPositionSpray" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="140, 10" size="25, 16" title="Pan" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularPanSpray" origin="165, 10" size="30, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="140, 28" size="55, 20" control-tag="GranularPanSpray" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="205, 10" size="30, 16" title="Rev" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularReverseProb" origin="230, 10" size="30, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="205, 28" size="55, 20" control-tag="GranularReverseProb" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="10, 55" size="50, 16" title="Freeze" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CCheckBox" origin="10, 71" size="50, 22" control-tag="GranularFreeze" title="" font="value-font" font-color="text"/>
      <view class="CTextLabel" origin="70, 55" size="30, 16" title="Tex" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularTexture" origin="95, 55" size="30, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="70, 71" size="55, 20" control-tag="GranularTexture" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="135, 55" size="30, 16" title="Wid" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="GranularStereoWidth" origin="160, 55" size="30, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="135, 71" size="55, 20" control-tag="GranularStereoWidth" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
    </view>
  </template>
  <template name="SpectralPanel" class="CViewContainer" origin="0, 0" size="860, 400" background-color="panel" transparent="false">
    <view class="CTextLabel" origin="10, 5" size="200, 22" title="SPECTRAL DELAY" font="section-font" font-color="accent" transparent="true"/>
    <view class="FieldsetContainer" origin="10, 30" size="280, 157" fieldset-title="TIME &amp; MIX" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CViewContainer" origin="10, 10" size="55, 68" sub-controller="SpectralTimeSyncController" transparent="true">
        <view class="CParamDisplay" control-tag="SpectralBaseDelay" origin="0, 0" size="55, 13" font="label-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="center" value-precision="0"/>
        <view class="ArcKnob" origin="5, 13" size="45, 45" control-tag="SpectralBaseDelay" default-value="0.25" arc-color="accent" guide-color="slider-track" arc-width="2.5"/>
        <view class="ToggleButton" origin="3, 55" size="49, 10" control-tag="SpectralTimeMode" default-value="0" title="sync" on-color="accent" off-color="text-dim" font-size="7"/>
      </view>
      <view class="CTextLabel" origin="75, 10" size="65, 16" title="Feedback" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="SpectralFeedback" origin="140, 10" size="65, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="75, 28" size="195, 20" control-tag="SpectralFeedback" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="10, 82" size="130, 16" title="Dry/Wet" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="SpectralDryWet" origin="140, 82" size="130, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 100" size="260, 20" control-tag="SpectralDryWet" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
    </view>
    <view class="FieldsetContainer" origin="300, 30" size="270, 157" fieldset-title="SPECTRAL ANALYSIS" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CTextLabel" origin="10, 10" size="245, 16" title="FFT Size" font="label-font" font-color="text-dim" transparent="true" text-alignment="center"/>
      <view class="CSegmentButton" origin="10, 28" size="245, 22" control-tag="SpectralFFTSize" style="horizontal" segment-names="512,1024,2048,4096" selection-mode="kSingle" font="value-font" text-color="text" text-color-highlighted="text-light" frame-color="border" gradient="segment-bg" gradient-highlighted="segment-bg-selected"/>
      <view class="CTextLabel" origin="10, 55" size="245, 16" title="Direction" font="label-font" font-color="text-dim" transparent="true" text-alignment="center"/>
      <view class="CSegmentButton" origin="10, 73" size="245, 22" control-tag="SpectralSpreadDirection" style="horizontal" segment-names="Low-&gt;High,High-&gt;Low,Center Out" selection-mode="kSingle" font="value-font" text-color="text" text-color-highlighted="text-light" frame-color="border" gradient="segment-bg" gradient-highlighted="segment-bg-selected"/>
      <view class="CTextLabel" origin="10, 100" size="55, 16" title="Spread" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="SpectralSpread" origin="65, 100" size="60, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 118" size="115, 20" control-tag="SpectralSpread" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="135, 100" size="120, 16" title="Curve" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CSegmentButton" origin="135, 118" size="120, 22" control-tag="SpectralSpreadCurve" style="horizontal" segment-names="Linear,Log" selection-mode="kSingle" font="value-font" text-color="text" text-color-highlighted="text-light" frame-color="border" gradient="segment-bg" gradient-highlighted="segment-bg-selected"/>
    </view>
