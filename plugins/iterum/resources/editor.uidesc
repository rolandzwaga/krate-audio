  <template name="FreezePanel" class="CViewContainer" origin="0, 0" size="860, 400" background-color="panel" transparent="false">
    <view class="CTextLabel" origin="10, 5" size="200, 22" title="PATTERN FREEZE MODE" font="section-font" font-color="accent" transparent="true"/>
    <view class="FieldsetContainer" origin="10, 30" size="280, 77" fieldset-title="PATTERN" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CTextLabel" origin="10, 10" size="50, 16" title="Type" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="COptionMenu" origin="60, 8" size="100, 22" control-tag="FreezePatternType" font="value-font" font-color="text" back-color="sidebar" frame-color="border" frame-width="1" style-round-rect="true" round-rect-radius="2" mouse-enabled="true" wants-focus="true" menu-popup-style="true"/>
      <view class="CTextLabel" origin="10, 34" size="65, 16" title="Dry/Wet" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="FreezeDryWet" origin="225, 34" size="45, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 52" size="260, 20" control-tag="FreezeDryWet" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
    </view>
    <view class="FieldsetContainer" origin="10, 130" size="280, 62" fieldset-title="SLICE" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CTextLabel" origin="10, 10" size="50, 16" title="Length" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="FreezeSliceLength" origin="60, 10" size="45, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 28" size="100, 20" control-tag="FreezeSliceLength" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="120, 10" size="50, 16" title="Mode" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CSegmentButton" origin="120, 28" size="150, 22" control-tag="FreezeSliceMode" style="horizontal" segment-names="Fixed,Variable" selection-mode="kSingle" font="value-font" text-color="text" text-color-highlighted="text-light" frame-color="border" gradient="segment-bg" gradient-highlighted="segment-bg-selected"/>
    </view>
    <view class="FieldsetContainer" origin="300, 30" size="270, 77" fieldset-title="EUCLIDEAN" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CTextLabel" origin="10, 10" size="35, 16" title="Steps" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="FreezeEuclideanSteps" origin="45, 10" size="25, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 28" size="60, 20" control-tag="FreezeEuclideanSteps" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="75, 10" size="30, 16" title="Hits" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="FreezeEuclideanHits" origin="105, 10" size="25, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="75, 28" size="60, 20" control-tag="FreezeEuclideanHits" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="140, 10" size="35, 16" title="Rot" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="FreezeEuclideanRotation" origin="175, 10" size="25, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="140, 28" size="60, 20" control-tag="FreezeEuclideanRotation" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="205, 10" size="35, 16" title="Rate" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="COptionMenu" origin="205, 28" size="55, 22" control-tag="FreezePatternRate" font="value-font" font-color="text" back-color="sidebar" frame-color="border" frame-width="1" style-round-rect="true" round-rect-radius="2" mouse-enabled="true" wants-focus="true" menu-popup-style="true"/>
    </view>
    <view class="FieldsetContainer" origin="300, 30" size="270, 77" fieldset-title="GRANULAR SCATTER" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CTextLabel" origin="10, 10" size="45, 16" title="Density" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="FreezeGranularDensity" origin="55, 10" size="40, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 28" size="90, 20" control-tag="FreezeGranularDensity" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="105, 10" size="35, 16" title="Grain" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="FreezeGranularGrainSize" origin="140, 10" size="40, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="105, 28" size="75, 20" control-tag="FreezeGranularGrainSize" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="185, 10" size="40, 16" title="PosJit" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CSlider" origin="185, 28" size="35, 20" control-tag="FreezeGranularPositionJitter" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="225, 10" size="35, 16" title="SzJit" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CSlider" origin="225, 28" size="35, 20" control-tag="FreezeGranularSizeJitter" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
    </view>
    <view class="FieldsetContainer" origin="300, 30" size="270, 82" fieldset-title="HARMONIC DRONES" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CTextLabel" origin="10, 10" size="40, 16" title="Voices" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="FreezeDroneVoiceCount" origin="50, 10" size="25, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 28" size="65, 20" control-tag="FreezeDroneVoiceCount" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="80, 10" size="40, 16" title="Intrvl" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="COptionMenu" origin="80, 28" size="60, 22" control-tag="FreezeDroneInterval" font="value-font" font-color="text" back-color="sidebar" frame-color="border" frame-width="1" style-round-rect="true" round-rect-radius="2" mouse-enabled="true" wants-focus="true" menu-popup-style="true"/>
      <view class="CTextLabel" origin="145, 10" size="30, 16" title="Drift" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CSlider" origin="145, 28" size="55, 20" control-tag="FreezeDroneDrift" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="205, 10" size="35, 16" title="Rate" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CSlider" origin="205, 28" size="55, 20" control-tag="FreezeDroneDriftRate" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
    </view>
    <view class="FieldsetContainer" origin="300, 30" size="270, 147" fieldset-title="NOISE BURSTS" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CTextLabel" origin="10, 10" size="35, 16" title="Color" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="COptionMenu" origin="10, 28" size="60, 22" control-tag="FreezeNoiseColor" font="value-font" font-color="text" back-color="sidebar" frame-color="border" frame-width="1" style-round-rect="true" round-rect-radius="2" mouse-enabled="true" wants-focus="true" menu-popup-style="true"/>
      <view class="CTextLabel" origin="75, 10" size="35, 16" title="Rate" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="COptionMenu" origin="75, 28" size="55, 22" control-tag="FreezeNoiseBurstRate" font="value-font" font-color="text" back-color="sidebar" frame-color="border" frame-width="1" style-round-rect="true" round-rect-radius="2" mouse-enabled="true" wants-focus="true" menu-popup-style="true"/>
      <view class="CTextLabel" origin="10, 53" size="35, 16" title="Filter" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CSegmentButton" origin="10, 73" size="240, 22" control-tag="FreezeNoiseFilterType" style="horizontal" segment-names="LP,HP,BP" selection-mode="kSingle" font="value-font" text-color="text" text-color-highlighted="text-light" frame-color="border" gradient="segment-bg" gradient-highlighted="segment-bg-selected"/>
      <view class="CTextLabel" origin="137, 11" size="35, 16" title="Cut" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CSlider" origin="137, 29" size="113, 20" control-tag="FreezeNoiseFilterCutoff" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="10, 102" size="40, 10" title="Sweep" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CSlider" origin="10, 122" size="240, 20" control-tag="FreezeNoiseFilterSweep" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
    </view>
    <view class="FieldsetContainer" origin="10, 220" size="280, 102" fieldset-title="ENVELOPE" fieldset-color="border" fieldset-title-color="accent" transparent="true">
      <view class="CTextLabel" origin="10, 10" size="35, 16" title="Atk" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="FreezeEnvelopeAttack" origin="50, 10" size="40, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="10, 28" size="80, 20" control-tag="FreezeEnvelopeAttack" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="95, 10" size="35, 16" title="Rel" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CParamDisplay" control-tag="FreezeEnvelopeRelease" origin="135, 10" size="40, 16" font="value-font" font-color="text" back-color="~ TransparentCColor" frame-color="~ TransparentCColor" text-alignment="right" value-precision="0"/>
      <view class="CSlider" origin="95, 28" size="80, 20" control-tag="FreezeEnvelopeRelease" orientation="horizontal" draw-frame="true" draw-back="true" draw-value="true" frame-color="border" back-color="slider-track" value-color="accent"/>
      <view class="CTextLabel" origin="10, 56" size="40, 16" title="Shape" font="label-font" font-color="text-dim" transparent="true"/>
      <view class="CSegmentButton" origin="10, 74" size="250, 22" control-tag="FreezeEnvelopeShape" style="horizontal" segment-names="Lin,Exp" selection-mode="kSingle" font="value-font" text-color="text" text-color-highlighted="text-light" frame-color="border" gradient="segment-bg" gradient-highlighted="segment-bg-selected"/>
    </view>
  </template>
  <template name="Editor" class="CViewContainer" origin="0, 0" size="900, 600" background-color="background" minSize="900, 600" maxSize="1200, 900" autosize="left right top bottom">
    <view class="CViewContainer" origin="0, 0" size="900, 50" background-color="header" autosize="left right" mouse-enabled="true">
      <view class="CTextLabel" origin="15, 10" size="80, 30" title="ITERUM" font="title-font" font-color="accent" text-alignment="left" transparent="true"/>
      <view class="IconSegmentButton" origin="100, 5" size="790, 40" control-tag="Mode" default-value="0" layout-mode="icon-and-text" segment-names="Granular,Spectral,Shimmer,Tape,BBD,Digital,PingPong,Reverse,MultiTap,Freeze" segment-icons="granular,spectral,shimmer,tape,bbd,digital,pingpong,reverse,multitap,freeze" selected-color="#1e1e22ff" unselected-color="slider-track" highlight-color="slider-track" frame-color="border"/>
    </view>
    <view class="UIViewSwitchContainer" origin="20, 60" size="860, 400" background-color="panel" transparent="false" template-names="GranularPanel,SpectralPanel,ShimmerPanel,TapePanel,BBDPanel,DigitalPanel,PingPongPanel,ReversePanel,MultiTapPanel,FreezePanel" template-switch-control="Mode"/>
    <view class="CViewContainer" origin="0, 560" size="900, 40" background-color="header" autosize="left right bottom">
      <view class="CTextLabel" control-tag="9999" origin="15, 12" size="200, 16" title="Iterum v1.0.0" font="value-font" font-color="text-dim" transparent="true"/>
      <view custom-view-name="CheckForUpdatesButton" origin="580, 7" size="110, 26"/>
      <view custom-view-name="SavePresetButton" origin="700, 7" size="85, 26"/>
      <view custom-view-name="PresetBrowserButton" origin="795, 7" size="90, 26"/>
    </view>
    <!-- Update Banner (last child = paints on top of everything) -->
    <view custom-view-name="UpdateBanner" origin="0, 0" size="900, 60" autosize="left right"/>
  </template>
</vstgui-ui-description>