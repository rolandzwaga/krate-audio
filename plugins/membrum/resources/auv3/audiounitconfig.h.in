// Channel capabilities describe ONLY the main output bus (element 0 in
// AU vocabulary). Membrum's 15 aux stereo buses are exposed as separate
// AU output elements at runtime; they are NOT encoded here, and AU's
// flat channel-count format cannot represent them anyway.
//
// "02" = one config: 0 in, 2 out (stereo instrument, no sidechain).
// Previous value "00220032" parsed as (0,0)+(2,2)+(0,0)+(3,2) per the
// digit-pair format and caused AU host init to fail because (2,2)
// declares stereo audio input the processor does not provide.
#define kSupportedNumChannels     02

