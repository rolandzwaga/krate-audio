// Channel capabilities. Format: each digit is one integer, pairs interpreted
// as (input, output) configs. See AUv3Wrapper.mm parser (substringWithRange:1).
//   "02"   = one config: 0 in, 2 out  (instrument, no sidechain)   <- THIS PLUGIN
//   "0222" = two configs: (0in,2out) + (2in,2out)                  (instrument + sidechain)
//   "1122" = two configs: (1in,1out) + (2in,2out)                  (mono+stereo effect)
// Previously was "0022" which parsed as (0,0)+(2,2) and made Ableton fail init
// because the VST3 processor refuses any non-zero audio input bus.
#define kSupportedNumChannels     02

