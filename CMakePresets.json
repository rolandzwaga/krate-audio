{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 20,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "SMTG_CXX_STANDARD": "20",
                "VSTWORK_BUILD_TESTS": "ON"
            }
        },
        {
            "name": "windows-x64-debug",
            "displayName": "Windows x64 Debug",
            "inherits": "base",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-x64-release",
            "displayName": "Windows x64 Release",
            "inherits": "base",
            "generator": "Visual Studio 17 2022",
            "architecture": "x64",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-ninja",
            "displayName": "Windows Ninja (for clang-tidy)",
            "description": "Ninja build for generating compile_commands.json. Run from VS Developer Command Prompt.",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-ninja-dev",
            "displayName": "Windows Ninja Dev (fast agent iteration)",
            "description": "Lean Ninja build for fast edit->verify loops. Ninja enables the ccache compiler launcher (the VS generator ignores it); heavy optional tools are off. Run from a VS Developer Command Prompt. ccache/sccache is used automatically if on PATH.",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "USE_CCACHE": "ON",
                "VSTWORK_BUILD_MEMBRUM_FIT": "OFF",
                "BUILD_CONTROL_TESTBENCH": "OFF"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Windows"
            }
        },
        {
            "name": "windows-ninja-timing",
            "displayName": "Windows Ninja Timing (build-time instrumentation)",
            "description": "Ninja build with MSVC /Bt+ /d2cgsummary. Capture build stdout to a log, then: node tools/aggregate-build-times.js --build build/windows-ninja-timing --msvc-log <log>. Run from a VS Developer Command Prompt.",
            "inherits": "windows-ninja",
            "cacheVariables": {
                "KRATE_BUILD_TIMING": "ON"
            }
        },
        {
            "name": "macos-debug",
            "displayName": "macOS Debug",
            "inherits": "base",
            "generator": "Xcode",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "macos-release",
            "displayName": "macOS Release",
            "inherits": "base",
            "generator": "Xcode",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Darwin"
            }
        },
        {
            "name": "linux-debug",
            "displayName": "Linux Debug",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-release",
            "displayName": "Linux Release",
            "inherits": "base",
            "generator": "Ninja",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            },
            "condition": {
                "type": "equals",
                "lhs": "${hostSystemName}",
                "rhs": "Linux"
            }
        },
        {
            "name": "linux-timing",
            "displayName": "Linux Timing (build-time instrumentation)",
            "description": "Clang/GCC Ninja build with -ftime-trace. Emits per-TU <obj>.json traces; then: node tools/aggregate-build-times.js --build build/linux-timing",
            "inherits": "linux-release",
            "cacheVariables": {
                "KRATE_BUILD_TIMING": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "windows-x64-debug",
            "configurePreset": "windows-x64-debug",
            "configuration": "Debug"
        },
        {
            "name": "windows-x64-release",
            "configurePreset": "windows-x64-release",
            "configuration": "Release"
        },
        {
            "name": "windows-ninja-dev",
            "configurePreset": "windows-ninja-dev"
        },
        {
            "name": "windows-ninja-timing",
            "configurePreset": "windows-ninja-timing"
        },
        {
            "name": "macos-debug",
            "configurePreset": "macos-debug",
            "configuration": "Debug"
        },
        {
            "name": "macos-release",
            "configurePreset": "macos-release",
            "configuration": "Release"
        },
        {
            "name": "linux-debug",
            "configurePreset": "linux-debug"
        },
        {
            "name": "linux-release",
            "configurePreset": "linux-release"
        },
        {
            "name": "linux-timing",
            "configurePreset": "linux-timing"
        }
    ],
    "testPresets": [
        {
            "name": "windows-x64-debug",
            "configurePreset": "windows-x64-debug",
            "configuration": "Debug",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "windows-x64-release",
            "configurePreset": "windows-x64-release",
            "configuration": "Release",
            "output": {
                "outputOnFailure": true
            }
        },
        {
            "name": "windows-ninja-dev",
            "configurePreset": "windows-ninja-dev",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
